# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here

# ── Optional ──────────────────────────────────────────────────────────────────
COMMAND_PREFIX=c.
DB_PATH=phonebooth.db
QUEUE_TIMEOUT=10

# GIF Report Logging
# Set to a channel ID where GIF reports are forwarded so you can review them.
# Leave as 0 to disable (reports still stored in the DB, reviewable with c.reports).
REPORT_LOG_CHANNEL_ID=0
